<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Ai.McuUiStudio.App.Views.FolderPickerDialog"
        mc:Ignorable="d"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
        ColumnDefinitions="*,Auto,Auto,Auto"
        Margin="16">
    <TextBox Grid.Row="0"
             Grid.Column="0"
             Margin="0,0,8,0"
             Text="{Binding PathInput}" />
    <Button Grid.Row="0"
            Grid.Column="1"
            Margin="0,0,8,0"
            Content="{Binding GoLabel}"
            Click="GoClick" />
    <Button Grid.Row="0"
            Grid.Column="2"
            Margin="0,0,8,0"
            Content="{Binding UpLabel}"
            Click="UpClick" />
    <Button Grid.Row="0"
            Grid.Column="3"
            Content="{Binding HomeLabel}"
            Click="HomeClick" />

    <TextBlock Grid.Row="1"
               Grid.ColumnSpan="4"
               Margin="0,10,0,10"
               Text="{Binding CurrentPath}"
               FontWeight="SemiBold"
               TextWrapping="Wrap" />

    <Border Grid.Row="2"
            Grid.ColumnSpan="4"
            BorderBrush="#22000000"
            BorderThickness="1">
      <ListBox x:Name="FolderListBox"
               ItemsSource="{Binding Entries}"
               SelectedItem="{Binding SelectedEntry}"
               DoubleTapped="FolderListDoubleTapped">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="8,6" Spacing="2">
              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding FullPath}" Opacity="0.65" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <TextBlock Grid.Row="3"
               Grid.ColumnSpan="4"
               Margin="0,10,0,0"
               Foreground="#A85A20"
               Text="{Binding ErrorText}"
               TextWrapping="Wrap"
               IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <StackPanel Grid.Row="4"
                Grid.ColumnSpan="4"
                Margin="0,16,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="{Binding OpenLabel}"
              Click="OpenClick"
              IsEnabled="{Binding CanOpenSelected}" />
      <Button Content="{Binding SelectCurrentLabel}"
              Click="SelectCurrentClick" />
      <Button Content="{Binding CancelLabel}"
              Click="CancelClick" />
    </StackPanel>
  </Grid>
</Window>
